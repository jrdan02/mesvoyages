{% extends "basefront.html.twig" %}
{% block body %}
    <div class="row mt-3">
        <div class="col">
            <h5> {{ visite.datecreationstring }}</h5>
            <h1 class="text-primary mt-5">{{ visite.ville }}</h1>
            <h3>{{ visite.pays }}</h3>
            <h3>{{visite.environnement}}</h3>
            {% if visite.note>=10 %}
                <h2 class="text-success mt-5">{{ visite.note }}/20</h2>
            {% else %}
                <h2 class="text-danger mt-5">{{ visite.note }}/20</h2>
            {% endif %}
            <h5 class="mt-5">t° entre {{ visite.tempmin }}° et {{ visite.tempmax }}°</h5>      
            <p class="mt-5"><strong>Environnement :</strong></p>
            {% for environnement in visite.environnement %}
                {{ environnement.nom }}
            {% endfor %}                    
        </div>
        <div class="col">
              {% if visite.imageName %}
        <img src="{{ app.request.getBasePath() ~ vich_uploader_asset(visite , 'imageFile') }}"
             class="card-img-top" style="width:100px; height:auto;">
    {% else %}
        <p>(Aucune image trouvée)</p>
    {% endif %}
        </div>
    </div>
    <div class="row mt-5">
        <div class="col md-12">
            <p><strong>mon avis :</strong></p>
            <p>
                {{ visite.avis }}
            </p>
        </div>
    </div>
{% endblock %}